struct Vec {
    x : float = 2
    y : float = 2
    z : float = 2
    
    #~ Implement "self" keyword
    
    func magnitude(self) : float {
        return sqrt(self.x^2 + self.y^2 + self.z^2)
    }
    ~#
    
    pub const func dist(vec_1 : Vec, vec_2 : Vec) : float {
        return sqrt((vec_1.x - vec_2.x)^2 + (vec_1.y - vec_2.y)^2 + (vec_1.z - vec_2.z)^2)
    }
    
    const func sqrt(x float) : float {
        return x^(1/2)
    }
}

let vec_1 = Vec{ 
    x: 1,
    y: 0.5,
    z: 0,
}

let vec_2 = Vec{
    .x = 0,
    .y = 0.5,
    .z = 1,
}

println("{}", Vec::dist(vec_1, vec_2))