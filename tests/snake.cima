# TODO: Move this example to structs instead of arrays
# TODO: Implement enums

struct Cell {
    static const Head  : char = '@'
    static const Body  : char = '#'
    static const Space : char = '.'
    static const Apple : char = '%'
}

struct Status {
    static Win  : int = 0
    static Lose : int = 1
}

struct Difficulty {
    static const Casual : int = 0
    static const Normal : int = 1
}

struct Position {
    x : int
    y : int   
}

struct Snake {
    segments : [Position]
    last_pos : Position
}

struct Field {
    size : int
    snake : Snake
    apple : Position
    appleSpawned : bool
    
    # TODO: Implement 'self'
    
    func print(field: Field) {
        for let y = 0; y < field.size; ++y {
            for let x = 0; x < field.size; ++x {
                print("{get_cell(field, @Position{x, y})}")
            }
            print("\n")
        }
    }
}

struct Game {
    field      : Field
    status     : int
    difficulty : int
    debug      : bool
}

let game : Game
game = game_init()

main_loop(game)

println("Press any key to exit.")
read_key()

func game_init() {
    const fieldSize = 8

    @Game{
        field: @Field{
                   size: fieldSize
                   snake: @Snake{
                                  segments: [
                                      @Position{
                                          x: fieldSize/2,
                                          y: fieldSize/2,
                                      }
                                  ]
                               }
                   appleSpawned: false
               }
        status: Status.Win
        difficulty: Difficulty.Normal
        debug: false
    }
}

func main_loop(game: Game){
    forever {
        println("What difficulty do you chose? (Casual\\Normal)")
        
        const choice = readln(false)
        while choice != "Casual" and choice != "Normal" {
            choice = readln(false)
            
            clear()
            println("What difficulty do you chose? (Casual\\Normal)")
        }
    
        clear()
        
        if choice == "Casual" { 
            game.difficulty = Difficulty.Casual
        }
        else {
            game.difficulty = Difficulty.Normal
        }
    
        game_loop(game)
        
        if game.status == Status.Win {
            clear()
            println("Congratulations!!!")
        }
        elif game.status == Status.Lose {
            clear()
            println("Ooops... You lost.")
        }
        else {
            println("\nERROR: Unexpected game status.");
            return;
        }
        
        println("Wanna try again? (Y\\n)")
        let ans = readkey()
        
        ans = if ans == 'Y' or ans == 'y' {
            'y'
        }
        elif ans == 'N' or ans == 'n' {
            'n'
        }
        else {
            'y'
        }
        
        clear()
        
        if ans == 'y' {
            game = game_init()
            continue
        }
        else {
            return
        }
    }
}

func game_loop(game: Game) {
    forever {
        if !game.field.appleSpawned {
            spawn_apple(game.field)
        }
    
        move_cursor(0, 0)
        game.field.print(game.field)
        
        let key = ' '
        
        while key != 'w' and key != 'a' and key != 's' and key != 'd' {
            key = readkey()
        
            if key == 'w' {
                move_up(game.field)
            }
            elif key == 'a' {
                move_left(game.field)
            }
            elif key == 's' {
                move_down(game.field)
            }
            elif key == 'd' {
                move_right(game.field)
            }
        }
        
        if game.difficulty == Difficulty.Casual {
            wrap_position(game.field)
        }
        
        if game.debug {
            println("{game}")
            readkey()
        }
        
        let head = game.field.snake.segments[0]
        
        if head.x == game.field.apple.x and head.y == game.field.apple.y {
            game.field.appleSpawned = false
            
            append(game.field.snake.segments, @Position{game.field.snake.last_pos.x, game.field.snake.last_pos.y})
            continue
        }
        
        for let i = 1; i < len(game.field.snake.segments); ++i {
            let segment = game.field.snake.segments[i]
        
            if head.x == segment.x and head.y == segment.y {
                game.status = Status.Lose
                return
            }
        }
        
        if head.x < 0 or head.x >= game.field.size {
            game.status = Status.Lose
            return
        }
        if head.y < 0 or head.y >= game.field.size {
            game.status = Status.Lose
            return
        }
    }
}

func spawn_apple(field: Field){
    let x = randint(0, field.size/2)
    let y = randint(0, field.size/2)
    
    let cell = get_cell(field, @Position{x, y})
    while cell == Cell.Head or cell == Cell.Body {
        x = (x + 1) % field.size
        y = (y + 1) % field.size
        cell = get_cell(field, @Position{x, y})
    }
    
    field.apple = @Position{x, y}
    field.appleSpawned = true
}

func get_cell(field: Field, pos: Position) : char {
    for let i = 0; i < len(field.snake.segments); ++i {
        const segment = field.snake.segments[i]
        
        if pos.x == segment.x and pos.y == segment.y {
            return if i == 0 {
                Cell.Head
            }
            else {
                Cell.Body
            }
        }
    }
    
    if field.appleSpawned and pos.x == field.apple.x and pos.y == field.apple.y {
        return Cell.Apple
    }
    
    return Cell.Space
}

func get_index(field: Field, pos: Position) : int {
    return pos.y * field.size + pos.x
}

func move_up(field: Field) {
    const head = field.snake.segments[0]
    
    field.snake.last_pos.x = head.x
    field.snake.last_pos.y = head.y

    --head.y
    move_body(field)
}

func move_down(field: Field) {
    const head = field.snake.segments[0]

    field.snake.last_pos.x = head.x
    field.snake.last_pos.y = head.y

    ++head.y
    move_body(field)
}

func move_right(field: Field) {
    const head = field.snake.segments[0]

    field.snake.last_pos.x = head.x
    field.snake.last_pos.y = head.y

    ++head.x
    move_body(field)
}

func move_left(field: Field) {
    const head = field.snake.segments[0]
    
    field.snake.last_pos.x = head.x
    field.snake.last_pos.y = head.y
    
    --head.x
    move_body(field)
}

func move_body(field: Field) {
    let pos : Position
    pos.x = field.snake.last_pos.x
    pos.y = field.snake.last_pos.y

    for let i = 1; i < len(field.snake.segments); ++i {
        const segment = field.snake.segments[i]
        let tmp : Position
        tmp.x = segment.x
        tmp.y = segment.y
        segment.x = pos.x
        segment.y = pos.y
        pos.x = tmp.x
        pos.y = tmp.y
    }
}

func wrap_position(field: Field) {
    for let i = 0; i < len(field.snake.segments); ++i {
        const segment = field.snake.segments[i]
        
        segment.x = segment.x % field.size;
        segment.y = segment.y % field.size;
        
        if segment.x < 0 {
            segment.x = segment.x + field.size
        }
        if segment.y < 0 {
            segment.y = segment.y + field.size
        }
    }
}