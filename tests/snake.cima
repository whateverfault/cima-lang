# TODO: Implement enums

struct Cell {
    static const Head  : char = '@'
    static const Body  : char = '#'
    static const Space : char = '.'
    static const Apple : char = '%'
}

struct Status {
    static const Win  : int = 0
    static const Lose : int = 1
}

struct Difficulty {
    static const Casual : int = 0
    static const Normal : int = 1
}

struct Position {
    x : int
    y : int   
}

struct Snake {
    segments : [Position]
    last_pos : Position
}

struct Field {
    size : int
    snake : Snake
    apple : Position
    appleSpawned : bool
    
    # TODO: Implement 'self'
    
    func print(self: &Field) {
        const pos = @Position{}
    
        for let y = 0; y < self.size; ++y {
            for let x = 0; x < self.size; ++x {
                pos.x = x;
                pos.y = y;
            
                print("{get_cell(self, pos)}")
            }
            print("\n")
        }
    }
}

struct Game {
    field      : Field
    status     : int
    difficulty : int
    debug      : bool
}

let game = @Game{}
game_init(&game)

main_loop(&game)

println("Press any key to exit.")
read_key()

func game_init(game : &Game) {
    const fieldSize = 8
    const initPos = @Position{
                        x: fieldSize/2,
                        y: fieldSize/2,
                    }

    game.field.size = fieldSize;
    game.field.snake.segments = [initPos]
    game.field.snake.last_pos = initPos
    game.field.appleSpawned = false
    game.status = Status.Win
    game.difficulty = Difficulty.Normal
    game.debug = false
}

func main_loop(game: &Game){
    forever {
        println("What difficulty do you chose? (Casual\\Normal)")
        
        let choice = readln(false)
        while choice != "Casual" and choice != "Normal" {
            choice = readln(false)
            
            clear()
            println("What difficulty do you chose? (Casual\\Normal)")
        }
    
        clear()
        
        if choice == "Casual" { 
            game.difficulty = Difficulty.Casual
        }
        else {
            game.difficulty = Difficulty.Normal
        }
    
        game_loop(game)
        
        if game.status == Status.Win {
            clear()
            println("Congratulations!!!")
        }
        elif game.status == Status.Lose {
            clear()
            println("Ooops... You lost.")
        }
        else {
            println("\nERROR: Unexpected game status.");
            return;
        }
        
        println("Wanna try again? (Y\\n)")
        let ans = readkey()
        
        ans = if ans == 'Y' or ans == 'y' {
            'y'
        }
        elif ans == 'N' or ans == 'n' {
            'n'
        }
        else {
            'y'
        }
        
        clear()
        
        if ans == 'y' {
            game_init(&game)
            continue
        }
        else {
            return
        }
    }
}

func game_loop(game: &Game) {
    let move_x = false
    let move_snake_up = true
    let move_snake_left = true

    forever {
        if !game.field.appleSpawned {
            spawn_apple(game.field)
        }
    
        move_cursor(0, 0)
        game.field.print(game.field)
        
        if game.debug {
            println("{game}")
        }
        
        let key = ' '
        
        while key != 'w' and key != 'a' and key != 's' and key != 'd' {
            if game.debug {            
                const head = game.field.snake.segments[0]
                const fieldSize = game.field.size
                
                if head.y == 0 or head.y == fieldSize - 1 {
                    move_x = !move_x

                    move_snake_left = if head.x == 0 {
                        false
                    }
                    elif head.x == fieldSize - 1 {
                        true
                    }
                    else {
                        move_snake_left
                    }
                }
                
                move_snake_up = if head.y == 0 {
                    false
                }
                elif head.y == fieldSize - 1 {
                    true
                }
                else {
                    move_snake_up
                }
                
                if move_x {
                    key = if move_snake_left {
                        'a'
                    }
                    else {
                        'd'
                    }
                }
                else {
                    key = if move_snake_up {
                        'w'
                    }
                    else {
                        's'
                    }
                }
            }
            else {
                key = readkey()
            }
        
            if key == 'w' {
                move_up(game.field)
            }
            elif key == 'a' {
                move_left(game.field)
            }
            elif key == 's' {
                move_down(game.field)
            }
            elif key == 'd' {
                move_right(game.field)
            }
        }
        
        if game.difficulty == Difficulty.Casual {
            wrap_position(game.field)
        }
        
        const head = game.field.snake.segments[0]
        
        if head.x == game.field.apple.x and head.y == game.field.apple.y {
            game.field.appleSpawned = false
            
            append(game.field.snake.segments, @Position{game.field.snake.last_pos.x, game.field.snake.last_pos.y})
            continue
        }
        
        for let i = 1; i < len(game.field.snake.segments); ++i {
            const segment = game.field.snake.segments[i]
        
            if head.x == segment.x and head.y == segment.y {
                game.status = Status.Lose
                return
            }
        }
        
        if head.x < 0 or head.x >= game.field.size {
            game.status = Status.Lose
            return
        }
        if head.y < 0 or head.y >= game.field.size {
            game.status = Status.Lose
            return
        }
    }
}

func spawn_apple(field: &Field){
    let pos = @Position{
                  randint(0, field.size/2)
                  randint(0, field.size/2)
              }
    
    let cell = get_cell(field, pos)
    while cell == Cell.Head or cell == Cell.Body {
        pos.x = (pos.x + 1) % field.size
        pos.y = (pos.y + 1) % field.size
        cell = get_cell(field, pos)
    }
    
    field.apple = pos
    field.appleSpawned = true
}

func get_cell(field: &Field, pos: &Position) : char {
    for let i = 0; i < len(field.snake.segments); ++i {
        const segment = field.snake.segments[i]
        
        if pos.x == segment.x and pos.y == segment.y {
            return if i == 0 {
                Cell.Head
            }
            else {
                Cell.Body
            }
        }
    }
    
    if field.appleSpawned and pos.x == field.apple.x and pos.y == field.apple.y {
        return Cell.Apple
    }
    
    return Cell.Space
}

func move_up(field: &Field) {
    const snake = &field.snake
    snake.last_pos = snake.segments[0]
    
    --snake.segments[0].y
    
    move_body(field)
}

func move_down(field: &Field) {
    const snake = &field.snake
    snake.last_pos = snake.segments[0]

    ++snake.segments[0].y
    move_body(field)
}

func move_right(field: &Field) {
    const snake = &field.snake
    snake.last_pos = snake.segments[0]

    ++snake.segments[0].x
    move_body(field)
}

func move_left(field: &Field) {
    const snake = &field.snake
    snake.last_pos = snake.segments[0]
    
    --snake.segments[0].x
    move_body(field)
}

func move_body(field: &Field) {
    let pos = field.snake.last_pos

    for let i = 1; i < len(field.snake.segments); ++i {
        const tmp = field.snake.segments[i]
        field.snake.segments[i] = pos
        pos = tmp
    }
}

func wrap_position(field: &Field) {
    for let i = 0; i < len(field.snake.segments); ++i {
        const segment = field.snake.segments[i]
        
        segment.x = segment.x % field.size;
        segment.y = segment.y % field.size;
        
        if segment.x < 0 {
            segment.x = segment.x + field.size
        }
        if segment.y < 0 {
            segment.y = segment.y + field.size
        }
    }
}